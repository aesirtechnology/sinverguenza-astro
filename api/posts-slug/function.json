{
  "scriptFile": "index.js",
  "bindings": [
    {
      "authLevel": "anonymous",
      "direction": "in",
      "methods": ["get", "put", "delete"],
      "name": "req",
      "route": "posts/{slug}",
      "type": "httpTrigger"
    },
    {
      "direction": "out",
      "name": "$return",
      "type": "http"
    }
  ]
}
