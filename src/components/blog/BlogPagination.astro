---
interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

function getPageHref(page: number): string {
  return page === 1 ? '/blog' : `/blog/${page}`;
}

const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
---

{totalPages > 1 ? (
  <nav class="blog-pagination" aria-label="Pagination">
    <a
      class:list={['blog-pagination__link', currentPage === 1 ? 'is-disabled' : '']}
      href={currentPage > 1 ? getPageHref(currentPage - 1) : undefined}
      aria-disabled={currentPage === 1}
    >
      Newer Posts
    </a>

    <div class="blog-pagination__pages">
      {pageNumbers.map((page) => (
        <a
          class:list={[
            'blog-pagination__page',
            currentPage === page ? 'is-current' : '',
          ]}
          href={getPageHref(page)}
          aria-current={currentPage === page ? 'page' : undefined}
        >
          {page}
        </a>
      ))}
    </div>

    <a
      class:list={[
        'blog-pagination__link',
        currentPage === totalPages ? 'is-disabled' : '',
      ]}
      href={currentPage < totalPages ? getPageHref(currentPage + 1) : undefined}
      aria-disabled={currentPage === totalPages}
    >
      Older Posts
    </a>
  </nav>
) : null}
