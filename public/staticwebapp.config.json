{
  "routes": [
    {
      "route": "/admin*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/posts/drafts",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/posts",
      "methods": ["POST"],
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/posts/*",
      "methods": ["PUT", "DELETE"],
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/trigger-rebuild",
      "methods": ["POST"],
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  }
}
